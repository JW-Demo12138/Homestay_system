<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.homestay.mapper.RatingMapper">

    <select id="selectAverageRatingByHomestayId" resultType="java.lang.Double">
        SELECT AVG(rating) FROM homestay_rating WHERE homestay_id = #{homestayId}
    </select>

</mapper>
